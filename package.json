{
  "name": "real-estate-analyst-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@rea/analyzer-web",
    "dev:web:clean": "rm -rf \"apps/analyzer-web/.next\" && npm run dev:web",
    "build:web": "npm run build --workspace=@rea/analyzer-web",
    "test": "npm run test --workspace=@rea/analysis && npm run test --workspace=@rea/chrome-extension && npm run test --workspace=@rea/analyzer-web"
  }
}
